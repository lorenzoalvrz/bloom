# NOTE: the repo's old `gitignore` file (no leading dot) was inert — git never read it.
# This is the real one. The old file can be deleted.

# --- generated build output (regenerated by build_final.py) ---
bloom-3d-local.html
dist/

# --- netlify export (contains real seed data — never commit) ---
netlify-export/
bloom-netlify.zip

# --- preview builds (each embeds the real seed — never commit) ---
bloom-preview-*.html
ds_keyed.png
ds-skin-blue-translucent.png
dsbg.gif

# --- render / scratch artifacts (recreated each session) ---
t_*.png
*_pv.png
*_sheet.png
crt_*.png
clean*_pv.png
xbox_*.png
wmp_*.png
test_*.html

# --- one-off render/verify scripts ---
r*.py
roff.py

# --- working copy of the embed (build reads embed_portal.json) ---
embed_new.json

# --- backend secrets + real-data store (NEVER commit) ---
backend/.dev.vars
backend/stack_v5.seed.json
.dev.vars

# --- python / os ---
__pycache__/
*.pyc
.DS_Store
